<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="website_teachers" name="Teachers Directory">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- ── Hero ────────────────────────────────── -->
                <div class="ypu-hero mb-4">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <h1 class="h2 mb-2">Meet Our Staff</h1>
                            <p class="mb-0">
                                Explore profiles by subject, category, and availability — no login required.
                            </p>
                        </div>
                        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                            <span class="ypu-badge"><t t-esc="total"/> profiles</span>
                        </div>
                    </div>
                </div>

                <!-- ── Filters ─────────────────────────────── -->
                <form class="row g-3 mb-4 ypu-filters" method="get" action="/teachers">
                    <div class="col-md-5">
                        <label class="form-label text-muted small mb-1">Search</label>
                        <input type="search" name="search" t-att-value="search"
                               class="form-control"
                               placeholder="Name, subject, or department…"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Category</label>
                        <select name="category_id" class="form-select">
                            <option value="">All categories</option>
                            <t t-foreach="categories" t-as="cat">
                                <option t-att-value="cat.id"
                                        t-att-selected="'selected' if selected_category == cat.id else None">
                                    <t t-esc="cat.name"/> (<t t-esc="cat.teacher_count"/>)
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted small mb-1">Availability</label>
                        <select name="available" class="form-select">
                            <option value="">Any</option>
                            <option value="1"
                                    t-att-selected="'selected' if selected_available == True else None">
                                Available
                            </option>
                            <option value="0"
                                    t-att-selected="'selected' if selected_available == False else None">
                                Unavailable
                            </option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100" type="submit">Filter</button>
                    </div>
                </form>

                <!-- ── Empty state ─────────────────────────── -->
                <t t-if="not teachers">
                    <div class="alert alert-info text-center">
                        No teachers match the current filters.
                    </div>
                </t>

                <t t-if="teachers">
                    <!-- Determine featured teacher (only on unfiltered first page) -->
                    <t t-set="has_filters"
                       t-value="bool((search or '').strip() or selected_category or selected_available is not None or pager['current'] != 1)"/>
                    <t t-set="show_featured" t-value="not has_filters"/>

                    <t t-set="featured" t-value="False"/>
                    <t t-if="show_featured">
                        <t t-foreach="teachers" t-as="t_rec">
                            <t t-if="t_rec.is_dean and not featured">
                                <t t-set="featured" t-value="t_rec"/>
                            </t>
                        </t>
                        <t t-if="not featured">
                            <t t-set="featured" t-value="teachers[0]"/>
                        </t>
                    </t>

                    <!-- ── Featured card ───────────────────── -->
                    <t t-if="featured">
                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div t-attf-class="ypu-card ypu-card--featured position-relative#{ ' ypu-card--has-action' if featured.link_url else '' }">

                                    <div class="d-flex">
                                        <div class="ypu-avatar me-3">
                                            <t t-if="featured.image_1920">
                                                <img t-attf-src="/web/image/ypu.teacher/{{ featured.id }}/image_1920"
                                                     alt="Photo"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="(featured.name or ' ')[0].upper()"/>
                                            </t>
                                        </div>

                                        <div class="flex-grow-1">
                                            <h5 class="mb-1"><t t-esc="featured.name"/></h5>

                                            <div class="mt-2">
                                                <t t-if="featured.rank">
                                                    <span class="ypu-tag"><t t-esc="featured.rank"/></span>
                                                </t>
                                                <t t-if="featured.position_id">
                                                    <span class="ypu-tag"><t t-esc="featured.position_id.name"/></span>
                                                </t>
                                                <t t-if="featured.category_id">
                                                    <span class="ypu-tag"><t t-esc="featured.category_id.name"/></span>
                                                </t>
                                            </div>

                                            <dl class="row mb-0 ypu-meta small mt-3">
                                                <dt>Email</dt>
                                                <dd>
                                                    <t t-if="featured.email">
                                                        <a t-attf-href="mailto:{{ featured.email }}"><t t-esc="featured.email"/></a>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </dd>
                                                <dt>LinkedIn</dt>
                                                <dd>
                                                    <t t-if="featured.linkedin_url">
                                                        <a t-att-href="featured.linkedin_url" target="_blank" rel="noopener noreferrer">Profile</a>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </dd>
                                                <dt>Google Scholar</dt>
                                                <dd>
                                                    <t t-if="featured.google_scholar">
                                                        <a t-att-href="featured.google_scholar" target="_blank" rel="noopener noreferrer">Profile</a>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </dd>
                                                <dt>Research Gate</dt>
                                                <dd>
                                                    <t t-if="featured.research_gate">
                                                        <a t-att-href="featured.research_gate" target="_blank" rel="noopener noreferrer">Profile</a>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </dd>
                                                <dt>Subject</dt>
                                                <dd><t t-esc="featured.subject or '-'"/></dd>
                                            </dl>

                                            <div class="ypu-card-action">
                                                <t t-if="featured.link_url">
                                                    <a class="btn btn-primary"
                                                       t-att-href="featured.link_url">View Profile</a>
                                                </t>
                                                <t t-if="featured.cv_download_url">
                                                    <a class="btn btn-outline-primary ms-2"
                                                       t-att-href="featured.cv_download_url"
                                                       t-att-target="None if featured.cv_download_url.startswith('/') else '_blank'">
                                                        <i class="fa fa-download me-1"/>Download CV</a>
                                                </t>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- ── Teacher grid ────────────────────── -->
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <t t-foreach="teachers" t-as="teacher">
                            <t t-if="not featured or teacher.id != featured.id">
                                <div class="col">
                                    <div t-attf-class="ypu-card h-100 p-3#{ ' ypu-card--has-action' if teacher.link_url else '' }">
                                        <div class="d-flex">
                                            <div class="ypu-avatar me-3">
                                                <t t-if="teacher.image_1920">
                                                    <img t-attf-src="/web/image/ypu.teacher/{{ teacher.id }}/image_1920"
                                                         alt="Photo"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="(teacher.name or ' ')[0].upper()"/>
                                                </t>
                                            </div>

                                            <div class="flex-grow-1">
                                                <div>
                                                    <h5 class="mb-1"><t t-esc="teacher.name"/></h5>
                                                </div>

                                                <div class="mt-2">
                                                    <t t-if="teacher.rank">
                                                        <span class="ypu-tag"><t t-esc="teacher.rank"/></span>
                                                    </t>
                                                    <t t-if="teacher.position_id">
                                                        <span class="ypu-tag"><t t-esc="teacher.position_id.name"/></span>
                                                    </t>
                                                    <t t-if="teacher.category_id">
                                                        <span class="ypu-tag"><t t-esc="teacher.category_id.name"/></span>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>

                                        <dl class="row mb-0 ypu-meta small mt-3">
                                            <dt>Email</dt>
                                            <dd>
                                                <t t-if="teacher.email">
                                                    <a t-attf-href="mailto:{{ teacher.email }}"><t t-esc="teacher.email"/></a>
                                                </t>
                                                <t t-else="">-</t>
                                            </dd>
                                            <dt>LinkedIn</dt>
                                            <dd>
                                                <t t-if="teacher.linkedin_url">
                                                    <a t-att-href="teacher.linkedin_url" target="_blank" rel="noopener noreferrer">Profile</a>
                                                </t>
                                                <t t-else="">-</t>
                                            </dd>
                                            <dt>Google Scholar</dt>
                                            <dd>
                                                <t t-if="teacher.google_scholar">
                                                    <a t-att-href="teacher.google_scholar" target="_blank" rel="noopener noreferrer">Profile</a>
                                                </t>
                                                <t t-else="">-</t>
                                            </dd>
                                            <dt>Research Gate</dt>
                                            <dd>
                                                <t t-if="teacher.research_gate">
                                                    <a t-att-href="teacher.research_gate" target="_blank" rel="noopener noreferrer">Profile</a>
                                                </t>
                                                <t t-else="">-</t>
                                            </dd>
                                            <dt>Subject</dt>
                                            <dd><t t-esc="teacher.subject or '-'"/></dd>
                                        </dl>

                                        <div class="ypu-card-action">
                                            <t t-if="teacher.link_url">
                                                <a class="btn btn-primary btn-sm"
                                                   t-att-href="teacher.link_url">View Profile</a>
                                            </t>
                                            <t t-if="teacher.cv_download_url">
                                                <a class="btn btn-outline-primary btn-sm ms-2"
                                                   t-att-href="teacher.cv_download_url"
                                                   t-att-target="None if teacher.cv_download_url.startswith('/') else '_blank'">
                                                    <i class="fa fa-download me-1"/>CV</a>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- ── Pagination ──────────────────────── -->
                    <t t-if="pager['total_pages'] > 1">
                        <nav class="mt-4" aria-label="Teacher pages">
                            <ul class="pagination justify-content-center">
                                <li t-attf-class="page-item #{'disabled' if not pager['prev_url'] else ''}">
                                    <a class="page-link"
                                       t-att-href="pager.get('prev_url') or '#'">&#8249;</a>
                                </li>
                                <t t-foreach="pager['pages']" t-as="pg">
                                    <li t-attf-class="page-item #{'active' if pg['active'] else ''}">
                                        <a class="page-link" t-att-href="pg['url']">
                                            <t t-esc="pg['num']"/>
                                        </a>
                                    </li>
                                </t>
                                <li t-attf-class="page-item #{'disabled' if not pager['next_url'] else ''}">
                                    <a class="page-link"
                                       t-att-href="pager.get('next_url') or '#'">&#8250;</a>
                                </li>
                            </ul>
                        </nav>
                    </t>

                </t>

            </div>
        </t>
    </template>

    <!-- ═══════════════ Individual Teacher Profile ═══════════════ -->
    <template id="website_teacher_profile" name="Teacher Profile">
        <t t-call="website.layout">
            <div id="wrap">

                <!-- ── Hero: gradient + photo + info + social links ─────────── -->
                <section style="background:linear-gradient(135deg,color-mix(in srgb,var(--bs-primary) 50%,#000000) 0%,var(--bs-primary) 100%);padding:56px 0 48px;">
                    <div class="container">
                        <a href="/teachers"
                           style="color:rgba(255,255,255,0.65);text-decoration:none;font-size:0.85rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:28px;">
                            <i class="fa fa-arrow-left"/> Back to Directory
                        </a>
                        <div class="row align-items-center g-5">

                            <!-- Left: name, rank, pills, links -->
                            <div class="col-lg-7 order-2 order-lg-1">
                                <h1 style="color:#fff;font-weight:700;font-size:2.4rem;margin-bottom:8px;">
                                    <t t-esc="teacher.name"/>
                                </h1>
                                <t t-if="teacher.rank or teacher.subject">
                                    <p style="color:rgba(255,255,255,0.8);font-size:1.1rem;margin-bottom:16px;">
                                        <t t-if="teacher.rank"><t t-esc="teacher.rank"/></t>
                                        <t t-if="teacher.rank and teacher.subject"> — </t>
                                        <t t-if="teacher.subject"><t t-esc="teacher.subject"/></t>
                                    </p>
                                </t>
                                <div class="d-flex flex-wrap gap-2" style="margin-bottom:24px;">
                                    <t t-if="teacher.department">
                                        <span style="background:rgba(255,255,255,0.15);color:#fff;padding:4px 12px;border-radius:20px;font-size:0.82rem;font-weight:500;">
                                            <t t-esc="teacher.department"/>
                                        </span>
                                    </t>
                                    <t t-if="teacher.position_id">
                                        <span style="background:rgba(255,255,255,0.15);color:#fff;padding:4px 12px;border-radius:20px;font-size:0.82rem;font-weight:500;">
                                            <t t-esc="teacher.position_id.name"/>
                                        </span>
                                    </t>
                                    <t t-if="teacher.category_id">
                                        <span style="background:rgba(255,255,255,0.15);color:#fff;padding:4px 12px;border-radius:20px;font-size:0.82rem;font-weight:500;">
                                            <t t-esc="teacher.category_id.name"/>
                                        </span>
                                    </t>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    <t t-if="teacher.linkedin_url">
                                        <a t-att-href="teacher.linkedin_url" target="_blank" rel="noopener noreferrer"
                                           class="ypu-social-btn">
                                            <i class="fa fa-linkedin"/> LinkedIn</a>
                                    </t>
                                    <t t-if="teacher.google_scholar">
                                        <a t-att-href="teacher.google_scholar" target="_blank" rel="noopener noreferrer"
                                           class="ypu-social-btn">
                                            <i class="fa fa-graduation-cap"/> Google Scholar</a>
                                    </t>
                                    <t t-if="teacher.research_gate">
                                        <a t-att-href="teacher.research_gate" target="_blank" rel="noopener noreferrer"
                                           class="ypu-social-btn">
                                            <i class="fa fa-flask"/> Research Gate</a>
                                    </t>
                                    <t t-if="teacher.email">
                                        <a t-attf-href="mailto:{{ teacher.email }}"
                                           class="ypu-social-btn">
                                            <i class="fa fa-envelope"/> Email</a>
                                    </t>
                                    <t t-if="teacher.cv_download_url">
                                        <a t-att-href="teacher.cv_download_url"
                                           t-att-target="None if teacher.cv_download_url.startswith('/') else '_blank'"
                                           class="ypu-social-btn ypu-social-btn--cv">
                                            <i class="fa fa-download"/> Download CV</a>
                                    </t>
                                </div>
                            </div>

                            <!-- Right: photo -->
                            <div class="col-lg-5 order-1 order-lg-2 text-center">
                                <t t-if="teacher.image_1920">
                                    <img t-attf-src="/web/image/ypu.teacher/{{ teacher.id }}/image_1920"
                                         t-att-alt="teacher.name"
                                         style="width:260px;height:260px;object-fit:cover;border-radius:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3);border:4px solid rgba(255,255,255,0.2);"/>
                                </t>
                                <t t-else="">
                                    <div style="width:200px;height:200px;border-radius:24px;background:rgba(255,255,255,0.1);border:4px solid rgba(255,255,255,0.2);font-size:4rem;font-weight:700;color:#fff;display:inline-flex;align-items:center;justify-content:center;">
                                        <t t-esc="(teacher.name or ' ')[0].upper()"/>
                                    </div>
                                </t>
                            </div>

                        </div>
                    </div>
                </section>

                <!-- ── Bio ──────────────────────────────────────────────────── -->
                <t t-if="teacher.bio">
                    <section style="background:#fff;padding:48px 0;border-bottom:1px solid #e5e7eb;">
                        <div class="container">
                            <div class="row justify-content-center">
                                <div class="col-lg-9">
                                    <div class="ypu-bio-content">
                                        <t t-out="teacher.bio"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </t>

                <!-- ── Tabs ─────────────────────────────────────────────────── -->
                <t t-set="has_personal"    t-value="bool(teacher.personal_info)"/>
                <t t-set="has_education"   t-value="bool(teacher.education)"/>
                <t t-set="has_career"      t-value="bool(teacher.career)"/>
                <t t-set="has_admin"       t-value="bool(teacher.administration)"/>
                <t t-set="has_supervising" t-value="bool(teacher.supervising)"/>
                <t t-set="has_pubs"        t-value="bool(teacher.publications)"/>
                <t t-set="has_courses"     t-value="bool(teacher.courses)"/>
                <t t-set="any_tab"         t-value="has_personal or has_education or has_career or has_admin or has_supervising or has_pubs or has_courses"/>

                <t t-if="any_tab">
                    <t t-set="active_first" t-value="'personal' if has_personal else 'education' if has_education else 'career' if has_career else 'admin' if has_admin else 'supervising' if has_supervising else 'pubs' if has_pubs else 'courses'"/>

                    <section style="background:#f8faff;padding:48px 0 64px;">
                        <div class="container">
                            <ul class="nav ypu-tabs-nav mb-4" role="tablist">
                                <t t-if="has_personal">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'personal' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-personal"
                                                type="button" role="tab">Personal Information</button>
                                    </li>
                                </t>
                                <t t-if="has_education">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'education' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-education"
                                                type="button" role="tab">Education</button>
                                    </li>
                                </t>
                                <t t-if="has_career">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'career' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-career"
                                                type="button" role="tab">Career</button>
                                    </li>
                                </t>
                                <t t-if="has_admin">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'admin' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-admin"
                                                type="button" role="tab">Administration</button>
                                    </li>
                                </t>
                                <t t-if="has_supervising">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'supervising' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-supervising"
                                                type="button" role="tab">Supervising</button>
                                    </li>
                                </t>
                                <t t-if="has_pubs">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'pubs' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-pubs"
                                                type="button" role="tab">Publications</button>
                                    </li>
                                </t>
                                <t t-if="has_courses">
                                    <li class="nav-item" role="presentation">
                                        <button t-attf-class="ypu-tab-btn{{ ' active' if active_first == 'courses' else '' }}"
                                                data-bs-toggle="tab" data-bs-target="#pane-courses"
                                                type="button" role="tab">Courses</button>
                                    </li>
                                </t>
                            </ul>

                            <div class="tab-content">
                                <t t-if="has_personal">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'personal' else '' }}"
                                         id="pane-personal" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.personal_info"/></div>
                                    </div>
                                </t>
                                <t t-if="has_education">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'education' else '' }}"
                                         id="pane-education" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.education"/></div>
                                    </div>
                                </t>
                                <t t-if="has_career">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'career' else '' }}"
                                         id="pane-career" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.career"/></div>
                                    </div>
                                </t>
                                <t t-if="has_admin">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'admin' else '' }}"
                                         id="pane-admin" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.administration"/></div>
                                    </div>
                                </t>
                                <t t-if="has_supervising">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'supervising' else '' }}"
                                         id="pane-supervising" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.supervising"/></div>
                                    </div>
                                </t>
                                <t t-if="has_pubs">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'pubs' else '' }}"
                                         id="pane-pubs" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.publications"/></div>
                                    </div>
                                </t>
                                <t t-if="has_courses">
                                    <div t-attf-class="tab-pane fade{{ ' show active' if active_first == 'courses' else '' }}"
                                         id="pane-courses" role="tabpanel">
                                        <div class="ypu-tab-content"><t t-out="teacher.courses"/></div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </section>
                </t>

                <!-- ── Extra editable zone ──────────────────────────────────── -->
                <div class="oe_structure oe_empty" id="oe_structure_profile_extra"/>

            </div><!-- /wrap -->
        </t>
    </template>

</odoo>
