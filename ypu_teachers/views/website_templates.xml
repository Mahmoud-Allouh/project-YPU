<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="website_teachers" name="Teachers Directory">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- ── Hero ────────────────────────────────── -->
                <div class="ypu-hero mb-4">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <h1 class="h2 mb-2">Meet Our Staff</h1>
                            <p class="mb-0">
                                Explore profiles by subject, category, and availability — no login required.
                            </p>
                        </div>
                        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                            <span class="ypu-badge"><t t-esc="total"/> profiles</span>
                        </div>
                    </div>
                </div>

                <!-- ── Filters ─────────────────────────────── -->
                <form class="row g-3 mb-4 ypu-filters" method="get" action="/teachers">
                    <div class="col-md-5">
                        <label class="form-label text-muted small mb-1">Search</label>
                        <input type="search" name="search" t-att-value="search"
                               class="form-control"
                               placeholder="Name, subject, or department…"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Category</label>
                        <select name="category_id" class="form-select">
                            <option value="">All categories</option>
                            <t t-foreach="categories" t-as="cat">
                                <option t-att-value="cat.id"
                                        t-att-selected="'selected' if selected_category == cat.id else None">
                                    <t t-esc="cat.name"/> (<t t-esc="cat.teacher_count"/>)
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted small mb-1">Availability</label>
                        <select name="available" class="form-select">
                            <option value="">Any</option>
                            <option value="1"
                                    t-att-selected="'selected' if selected_available == True else None">
                                Available
                            </option>
                            <option value="0"
                                    t-att-selected="'selected' if selected_available == False else None">
                                Unavailable
                            </option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100" type="submit">Filter</button>
                    </div>
                </form>

                <!-- ── Empty state ─────────────────────────── -->
                <t t-if="not teachers">
                    <div class="alert alert-info text-center">
                        No teachers match the current filters.
                    </div>
                </t>

                <t t-if="teachers">
                    <!-- Determine featured teacher (only on unfiltered first page) -->
                    <t t-set="has_filters"
                       t-value="bool((search or '').strip() or selected_category or selected_available is not None or pager['current'] != 1)"/>
                    <t t-set="show_featured" t-value="not has_filters"/>

                    <t t-set="featured" t-value="False"/>
                    <t t-if="show_featured">
                        <t t-foreach="teachers" t-as="t_rec">
                            <t t-if="t_rec.is_dean and not featured">
                                <t t-set="featured" t-value="t_rec"/>
                            </t>
                        </t>
                        <t t-if="not featured">
                            <t t-set="featured" t-value="teachers[0]"/>
                        </t>
                    </t>

                    <!-- ── Featured card ───────────────────── -->
                    <t t-if="featured">
                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div t-attf-class="ypu-card ypu-card--featured position-relative#{ ' ypu-card--has-action' if featured.show_link_button and featured.link_url else '' }">

                                    <span t-attf-class="ypu-badge position-absolute top-0 end-0 m-3 {{ 'available' if featured.available else 'unavailable' }}"
                                          style="z-index:2;">
                                        <t t-esc="'Available' if featured.available else 'Unavailable'"/>
                                    </span>

                                    <div class="d-flex">
                                        <div class="ypu-avatar me-3">
                                            <t t-if="featured.image_1920">
                                                <img t-attf-src="/web/image/ypu.teacher/{{ featured.id }}/image_1920"
                                                     alt="Photo"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="(featured.name or ' ')[0].upper()"/>
                                            </t>
                                        </div>

                                        <div class="flex-grow-1">
                                            <h5 class="mb-1"><t t-esc="featured.name"/></h5>

                                            <div class="mt-2">
                                                <t t-if="featured.rank">
                                                    <span class="ypu-tag"><t t-esc="featured.rank"/></span>
                                                </t>
                                                <t t-if="featured.position_id">
                                                    <span class="ypu-tag"><t t-esc="featured.position_id.name"/></span>
                                                </t>
                                                <t t-if="featured.category_id">
                                                    <span class="ypu-tag"><t t-esc="featured.category_id.name"/></span>
                                                </t>
                                            </div>

                                            <dl class="row mb-0 ypu-meta small mt-3">
                                                <dt>Email</dt>
                                                <dd><t t-esc="featured.email or '-'"/></dd>
                                                <dt>Phone</dt>
                                                <dd><t t-esc="featured.phone or '-'"/></dd>
                                                <dt>LinkedIn</dt>
                                                <dd><t t-esc="featured.linkedin_url or '-'"/></dd>
                                                <dt>Research Gate</dt>
                                                <dd><t t-esc="featured.research_gate or '-'"/></dd>
                                                <dt>Subject</dt>
                                                <dd><t t-esc="featured.subject or '-'"/></dd>
                                            </dl>

                                            <t t-if="featured.show_link_button and featured.link_url">
                                                <div class="ypu-card-action">
                                                    <a class="btn btn-primary"
                                                       t-att-href="featured.link_url">View Profile</a>
                                                </div>
                                            </t>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- ── Teacher grid ────────────────────── -->
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <t t-foreach="teachers" t-as="teacher">
                            <t t-if="not featured or teacher.id != featured.id">
                                <div class="col">
                                    <div t-attf-class="ypu-card h-100 p-3#{ ' ypu-card--has-action' if teacher.show_link_button and teacher.link_url else '' }">
                                        <div class="d-flex">
                                            <div class="ypu-avatar me-3">
                                                <t t-if="teacher.image_1920">
                                                    <img t-attf-src="/web/image/ypu.teacher/{{ teacher.id }}/image_1920"
                                                         alt="Photo"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="(teacher.name or ' ')[0].upper()"/>
                                                </t>
                                            </div>

                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <h5 class="mb-1"><t t-esc="teacher.name"/></h5>
                                                    </div>
                                                    <span t-attf-class="ypu-badge {{ 'available' if teacher.available else 'unavailable' }}">
                                                        <t t-esc="'Available' if teacher.available else 'Unavailable'"/>
                                                    </span>
                                                </div>

                                                <div class="mt-2">
                                                    <t t-if="teacher.rank">
                                                        <span class="ypu-tag"><t t-esc="teacher.rank"/></span>
                                                    </t>
                                                    <t t-if="teacher.position_id">
                                                        <span class="ypu-tag"><t t-esc="teacher.position_id.name"/></span>
                                                    </t>
                                                    <t t-if="teacher.category_id">
                                                        <span class="ypu-tag"><t t-esc="teacher.category_id.name"/></span>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>

                                        <dl class="row mb-0 ypu-meta small mt-3">
                                            <dt>Email</dt>
                                            <dd><t t-esc="teacher.email or '-'"/></dd>
                                            <dt>Phone</dt>
                                            <dd><t t-esc="teacher.phone or '-'"/></dd>
                                            <dt>LinkedIn</dt>
                                            <dd><t t-esc="teacher.linkedin_url or '-'"/></dd>
                                            <dt>Research Gate</dt>
                                            <dd><t t-esc="teacher.research_gate or '-'"/></dd>
                                            <dt>Subject</dt>
                                            <dd><t t-esc="teacher.subject or '-'"/></dd>
                                        </dl>

                                        <t t-if="teacher.show_link_button and teacher.link_url">
                                            <div class="ypu-card-action">
                                                <a class="btn btn-primary btn-sm"
                                                   t-att-href="teacher.link_url">View Profile</a>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- ── Pagination ──────────────────────── -->
                    <t t-if="pager['total_pages'] > 1">
                        <nav class="mt-4" aria-label="Teacher pages">
                            <ul class="pagination justify-content-center">
                                <li t-attf-class="page-item #{'disabled' if not pager['prev_url'] else ''}">
                                    <a class="page-link"
                                       t-att-href="pager.get('prev_url') or '#'">&#8249;</a>
                                </li>
                                <t t-foreach="pager['pages']" t-as="pg">
                                    <li t-attf-class="page-item #{'active' if pg['active'] else ''}">
                                        <a class="page-link" t-att-href="pg['url']">
                                            <t t-esc="pg['num']"/>
                                        </a>
                                    </li>
                                </t>
                                <li t-attf-class="page-item #{'disabled' if not pager['next_url'] else ''}">
                                    <a class="page-link"
                                       t-att-href="pager.get('next_url') or '#'">&#8250;</a>
                                </li>
                            </ul>
                        </nav>
                    </t>

                </t>

            </div>
        </t>
    </template>

</odoo>
