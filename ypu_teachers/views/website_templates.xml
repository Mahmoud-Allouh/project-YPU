<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="website_teachers" name="Teachers Directory">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- ── Hero ────────────────────────────────── -->
                <div class="ypu-hero mb-4">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <h1 class="h2 mb-2">Meet Our Staff</h1>
                            <p class="mb-0">
                                Explore profiles by subject, category, and availability — no login required.
                            </p>
                        </div>
                        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                            <span class="ypu-badge"><t t-esc="total"/> profiles</span>
                        </div>
                    </div>
                </div>

                <!-- ── Filters ─────────────────────────────── -->
                <form class="row g-3 mb-4 ypu-filters" method="get" action="/teachers">
                    <div class="col-md-5">
                        <label class="form-label text-muted small mb-1">Search</label>
                        <input type="search" name="search" t-att-value="search"
                               class="form-control"
                               placeholder="Name, subject, or department…"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Category</label>
                        <select name="category_id" class="form-select">
                            <option value="">All categories</option>
                            <t t-foreach="categories" t-as="cat">
                                <option t-att-value="cat.id"
                                        t-att-selected="'selected' if selected_category == cat.id else None">
                                    <t t-esc="cat.name"/> (<t t-esc="cat.teacher_count"/>)
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label text-muted small mb-1">Availability</label>
                        <select name="available" class="form-select">
                            <option value="">Any</option>
                            <option value="1"
                                    t-att-selected="'selected' if selected_available == True else None">
                                Available
                            </option>
                            <option value="0"
                                    t-att-selected="'selected' if selected_available == False else None">
                                Unavailable
                            </option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100" type="submit">Filter</button>
                    </div>
                </form>

                <!-- ── Empty state ─────────────────────────── -->
                <t t-if="not teachers">
                    <div class="alert alert-info text-center">
                        No teachers match the current filters.
                    </div>
                </t>

                <t t-if="teachers">
                    <!-- Determine featured teacher (only on unfiltered first page) -->
                    <t t-set="has_filters"
                       t-value="bool((search or '').strip() or selected_category or selected_available is not None or pager['current'] != 1)"/>
                    <t t-set="show_featured" t-value="not has_filters"/>

                    <t t-set="featured" t-value="False"/>
                    <t t-if="show_featured">
                        <t t-foreach="teachers" t-as="t_rec">
                            <t t-if="t_rec.is_dean and not featured">
                                <t t-set="featured" t-value="t_rec"/>
                            </t>
                        </t>
                        <t t-if="not featured">
                            <t t-set="featured" t-value="teachers[0]"/>
                        </t>
                    </t>

                    <!-- ── Featured card ───────────────────── -->
                    <t t-if="featured">
                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div t-attf-class="ypu-card ypu-card--featured position-relative#{ ' ypu-card--has-action' if featured.link_url else '' }">

                                    <span t-attf-class="ypu-badge position-absolute top-0 end-0 m-3 {{ 'available' if featured.available else 'unavailable' }}"
                                          style="z-index:2;">
                                        <t t-esc="'Available' if featured.available else 'Unavailable'"/>
                                    </span>

                                    <div class="d-flex">
                                        <div class="ypu-avatar me-3">
                                            <t t-if="featured.image_1920">
                                                <img t-attf-src="/web/image/ypu.teacher/{{ featured.id }}/image_1920"
                                                     alt="Photo"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="(featured.name or ' ')[0].upper()"/>
                                            </t>
                                        </div>

                                        <div class="flex-grow-1">
                                            <h5 class="mb-1"><t t-esc="featured.name"/></h5>

                                            <div class="mt-2">
                                                <t t-if="featured.rank">
                                                    <span class="ypu-tag"><t t-esc="featured.rank"/></span>
                                                </t>
                                                <t t-if="featured.position_id">
                                                    <span class="ypu-tag"><t t-esc="featured.position_id.name"/></span>
                                                </t>
                                                <t t-if="featured.category_id">
                                                    <span class="ypu-tag"><t t-esc="featured.category_id.name"/></span>
                                                </t>
                                            </div>

                                            <dl class="row mb-0 ypu-meta small mt-3">
                                                <dt>Email</dt>
                                                <dd><t t-esc="featured.email or '-'"/></dd>
                                                <dt>Phone</dt>
                                                <dd><t t-esc="featured.phone or '-'"/></dd>
                                                <dt>LinkedIn</dt>
                                                <dd><t t-esc="featured.linkedin_url or '-'"/></dd>
                                                <dt>Research Gate</dt>
                                                <dd><t t-esc="featured.research_gate or '-'"/></dd>
                                                <dt>Subject</dt>
                                                <dd><t t-esc="featured.subject or '-'"/></dd>
                                            </dl>

                                            <t t-if="featured.link_url">
                                                <div class="ypu-card-action">
                                                    <a class="btn btn-primary"
                                                       t-att-href="featured.link_url">View Profile</a>
                                                </div>
                                            </t>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- ── Teacher grid ────────────────────── -->
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        <t t-foreach="teachers" t-as="teacher">
                            <t t-if="not featured or teacher.id != featured.id">
                                <div class="col">
                                    <div t-attf-class="ypu-card h-100 p-3#{ ' ypu-card--has-action' if teacher.link_url else '' }">
                                        <div class="d-flex">
                                            <div class="ypu-avatar me-3">
                                                <t t-if="teacher.image_1920">
                                                    <img t-attf-src="/web/image/ypu.teacher/{{ teacher.id }}/image_1920"
                                                         alt="Photo"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="(teacher.name or ' ')[0].upper()"/>
                                                </t>
                                            </div>

                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <h5 class="mb-1"><t t-esc="teacher.name"/></h5>
                                                    </div>
                                                    <span t-attf-class="ypu-badge {{ 'available' if teacher.available else 'unavailable' }}">
                                                        <t t-esc="'Available' if teacher.available else 'Unavailable'"/>
                                                    </span>
                                                </div>

                                                <div class="mt-2">
                                                    <t t-if="teacher.rank">
                                                        <span class="ypu-tag"><t t-esc="teacher.rank"/></span>
                                                    </t>
                                                    <t t-if="teacher.position_id">
                                                        <span class="ypu-tag"><t t-esc="teacher.position_id.name"/></span>
                                                    </t>
                                                    <t t-if="teacher.category_id">
                                                        <span class="ypu-tag"><t t-esc="teacher.category_id.name"/></span>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>

                                        <dl class="row mb-0 ypu-meta small mt-3">
                                            <dt>Email</dt>
                                            <dd><t t-esc="teacher.email or '-'"/></dd>
                                            <dt>Phone</dt>
                                            <dd><t t-esc="teacher.phone or '-'"/></dd>
                                            <dt>LinkedIn</dt>
                                            <dd><t t-esc="teacher.linkedin_url or '-'"/></dd>
                                            <dt>Research Gate</dt>
                                            <dd><t t-esc="teacher.research_gate or '-'"/></dd>
                                            <dt>Subject</dt>
                                            <dd><t t-esc="teacher.subject or '-'"/></dd>
                                        </dl>

                                        <t t-if="teacher.link_url">
                                            <div class="ypu-card-action">
                                                <a class="btn btn-primary btn-sm"
                                                   t-att-href="teacher.link_url">View Profile</a>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- ── Pagination ──────────────────────── -->
                    <t t-if="pager['total_pages'] > 1">
                        <nav class="mt-4" aria-label="Teacher pages">
                            <ul class="pagination justify-content-center">
                                <li t-attf-class="page-item #{'disabled' if not pager['prev_url'] else ''}">
                                    <a class="page-link"
                                       t-att-href="pager.get('prev_url') or '#'">&#8249;</a>
                                </li>
                                <t t-foreach="pager['pages']" t-as="pg">
                                    <li t-attf-class="page-item #{'active' if pg['active'] else ''}">
                                        <a class="page-link" t-att-href="pg['url']">
                                            <t t-esc="pg['num']"/>
                                        </a>
                                    </li>
                                </t>
                                <li t-attf-class="page-item #{'disabled' if not pager['next_url'] else ''}">
                                    <a class="page-link"
                                       t-att-href="pager.get('next_url') or '#'">&#8250;</a>
                                </li>
                            </ul>
                        </nav>
                    </t>

                </t>

            </div>
        </t>
    </template>

    <!-- ═══════════════ Individual Teacher Profile ═══════════════ -->
    <template id="website_teacher_profile" name="Teacher Profile">
        <t t-call="website.layout">
            <div id="wrap">

                <!-- ── Section 1 : Name banner (same as existing pages: o_cc5 dark) ───── -->
                <section class="s_text_block pt40 o_colored_level o_cc o_cc5 pb32"
                         data-snippet="s_text_block">
                    <div class="s_allow_columns container text-center">
                        <a href="/teachers"
                           class="d-inline-block mb-3 small"
                           style="color:rgba(255,255,255,0.6); text-decoration:none;">
                            &#8592; Back to Directory
                        </a>
                        <h1 style="text-align:center;"><t t-esc="teacher.name"/></h1>
                        <div class="d-flex flex-wrap justify-content-center gap-2 mt-3">
                            <t t-if="teacher.rank">
                                <span class="badge rounded-pill"
                                      style="background:rgba(255,255,255,0.15); font-weight:500; font-size:0.85rem;">
                                    <t t-esc="teacher.rank"/>
                                </span>
                            </t>
                            <t t-if="teacher.position_id">
                                <span class="badge rounded-pill"
                                      style="background:rgba(255,255,255,0.15); font-weight:500; font-size:0.85rem;">
                                    <t t-esc="teacher.position_id.name"/>
                                </span>
                            </t>
                            <t t-if="teacher.category_id">
                                <span class="badge rounded-pill"
                                      style="background:rgba(255,255,255,0.15); font-weight:500; font-size:0.85rem;">
                                    <t t-esc="teacher.category_id.name"/>
                                </span>
                            </t>
                            <t t-if="teacher.department">
                                <span class="badge rounded-pill"
                                      style="background:rgba(255,255,255,0.15); font-weight:500; font-size:0.85rem;">
                                    <t t-esc="teacher.department"/>
                                </span>
                            </t>
                            <t t-if="teacher.available">
                                <span class="badge rounded-pill"
                                      style="background:rgba(34,197,94,0.3); color:#bbf7d0; font-weight:500; font-size:0.85rem;">
                                    Available
                                </span>
                            </t>
                            <t t-else="">
                                <span class="badge rounded-pill"
                                      style="background:rgba(148,163,184,0.2); color:#cbd5e1; font-weight:500; font-size:0.85rem;">
                                    Unavailable
                                </span>
                            </t>
                        </div>
                    </div>
                </section>

                <!-- ── Section 2 : Framed intro – photo + bio (o_cc2 light) ───────────── -->
                <section class="s_framed_intro o_colored_level o_cc o_cc2 pb48 pt48"
                         data-snippet="s_framed_intro" data-name="Framed Intro">
                    <div class="container">
                        <div class="row g-5 align-items-center">

                            <!-- Bio left -->
                            <div class="col-lg-7 order-2 order-lg-1">
                                <t t-if="teacher.bio">
                                    <div class="lead">
                                        <t t-out="teacher.bio"/>
                                    </div>
                                </t>
                                <t t-if="not teacher.bio and teacher.subject">
                                    <p class="lead"><strong><t t-esc="teacher.subject"/></strong></p>
                                </t>
                            </div>

                            <!-- Photo right -->
                            <div class="col-lg-5 order-1 order-lg-2 text-center">
                                <t t-if="teacher.image_1920">
                                    <img t-attf-src="/web/image/ypu.teacher/{{ teacher.id }}/image_1920"
                                         t-att-alt="teacher.name"
                                         class="img img-fluid o_we_custom_image rounded"
                                         style="max-width:380px; width:100%; border-radius:35px !important;
                                                box-shadow:0 20px 50px rgba(0,0,0,0.18);"/>
                                </t>
                                <t t-else="">
                                    <div class="mx-auto d-flex align-items-center justify-content-center rounded-circle"
                                         style="width:180px; height:180px; background:#e2e8f0; font-size:4rem; font-weight:700; color:#2563eb;">
                                        <t t-esc="(teacher.name or ' ')[0].upper()"/>
                                    </div>
                                </t>
                            </div>

                        </div>
                    </div>
                </section>

                <!-- ── Section 3 : Tabs (o_cc2) ─────────────────────────────────────── -->
                <t t-set="has_personal"    t-value="bool(teacher.personal_info)"/>
                <t t-set="has_contact"     t-value="bool(teacher.email or teacher.phone or teacher.linkedin_url or teacher.research_gate or teacher.contact_info)"/>
                <t t-set="has_education"   t-value="bool(teacher.education)"/>
                <t t-set="has_career"      t-value="bool(teacher.career)"/>
                <t t-set="has_admin"       t-value="bool(teacher.administration)"/>
                <t t-set="has_supervising" t-value="bool(teacher.supervising)"/>
                <t t-set="has_pubs"        t-value="bool(teacher.publications)"/>
                <t t-set="has_courses"     t-value="bool(teacher.courses)"/>
                <t t-set="any_tab"         t-value="has_personal or has_contact or has_education or has_career or has_admin or has_supervising or has_pubs or has_courses"/>

                <t t-if="any_tab">
                    <section class="s_tabs_common s_tabs o_colored_level pb80 o_cc o_cc2 pt16"
                             data-vcss="003" data-vxml="002"
                             data-snippet="s_tabs" data-name="Tabs">
                        <div class="container">
                            <div class="s_tabs_main o_direction_horizontal">

                                <!-- Tab headers -->
                                <div class="s_tabs_nav mb-3 overflow-y-hidden overflow-x-auto"
                                     data-name="Tab Header" role="navigation">
                                    <ul class="nav nav-underline flex-nowrap nav-justified"
                                        role="tablist">

                                        <t t-if="has_personal">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link text-break active"
                                                   data-bs-toggle="tab"
                                                   href="#pane-personal"
                                                   role="tab">Personal Information</a>
                                            </li>
                                        </t>
                                        <t t-if="has_contact">
                                            <li class="nav-item" role="presentation">
                                                <a t-attf-class="nav-link text-break{{ '' if has_personal else ' active' }}"
                                                   data-bs-toggle="tab"
                                                   href="#pane-contact"
                                                   role="tab">Contact Information</a>
                                            </li>
                                        </t>
                                        <t t-if="has_education">
                                            <li class="nav-item" role="presentation">
                                                <a t-attf-class="nav-link text-break{{ '' if (has_personal or has_contact) else ' active' }}"
                                                   data-bs-toggle="tab"
                                                   href="#pane-education"
                                                   role="tab">Education</a>
                                            </li>
                                        </t>
                                        <t t-if="has_career">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link text-break"
                                                   data-bs-toggle="tab"
                                                   href="#pane-career"
                                                   role="tab">Career</a>
                                            </li>
                                        </t>
                                        <t t-if="has_admin">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link text-break"
                                                   data-bs-toggle="tab"
                                                   href="#pane-admin"
                                                   role="tab">Administration</a>
                                            </li>
                                        </t>
                                        <t t-if="has_supervising">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link text-break"
                                                   data-bs-toggle="tab"
                                                   href="#pane-supervising"
                                                   role="tab">Supervising</a>
                                            </li>
                                        </t>
                                        <t t-if="has_pubs">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link text-break"
                                                   data-bs-toggle="tab"
                                                   href="#pane-pubs"
                                                   role="tab">Publications</a>
                                            </li>
                                        </t>
                                        <t t-if="has_courses">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link text-break"
                                                   data-bs-toggle="tab"
                                                   href="#pane-courses"
                                                   role="tab">Courses</a>
                                            </li>
                                        </t>

                                    </ul>
                                </div><!-- /s_tabs_nav -->

                                <!-- Tab panes -->
                                <div class="s_tabs_content tab-content">

                                    <t t-if="has_personal">
                                        <div class="tab-pane fade show active"
                                             id="pane-personal" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.personal_info"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_contact">
                                        <div t-attf-class="tab-pane fade{{ ' show active' if not has_personal else '' }}"
                                             id="pane-contact" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-if="teacher.email">
                                                            <p class="lead">Mobile phone: <t t-esc="teacher.phone or ''"/>  </p>
                                                            <p class="lead">E-mail: <a t-attf-href="mailto:{{ teacher.email }}"><t t-esc="teacher.email"/></a></p>
                                                        </t>
                                                        <t t-if="teacher.phone and not teacher.email">
                                                            <p class="lead">Phone: <t t-esc="teacher.phone"/></p>
                                                        </t>
                                                        <t t-if="teacher.linkedin_url">
                                                            <p class="lead">LinkedIn: <a t-att-href="teacher.linkedin_url" target="_blank" rel="noopener noreferrer"><t t-esc="teacher.linkedin_url"/></a></p>
                                                        </t>
                                                        <t t-if="teacher.research_gate">
                                                            <p class="lead">Research Gate: <a t-att-href="teacher.research_gate" target="_blank" rel="noopener noreferrer"><t t-esc="teacher.research_gate"/></a></p>
                                                        </t>
                                                        <t t-if="teacher.contact_info">
                                                            <t t-out="teacher.contact_info"/>
                                                        </t>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_education">
                                        <div t-attf-class="tab-pane fade{{ ' show active' if not has_personal and not has_contact else '' }}"
                                             id="pane-education" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.education"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_career">
                                        <div class="tab-pane fade" id="pane-career" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.career"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_admin">
                                        <div class="tab-pane fade" id="pane-admin" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.administration"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_supervising">
                                        <div class="tab-pane fade" id="pane-supervising" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.supervising"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_pubs">
                                        <div class="tab-pane fade" id="pane-pubs" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.publications"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                    <t t-if="has_courses">
                                        <div class="tab-pane fade" id="pane-courses" role="tabpanel">
                                            <div class="oe_structure oe_empty">
                                                <section class="s_text_block" data-snippet="s_text_block">
                                                    <div class="container s_allow_columns">
                                                        <t t-out="teacher.courses"/>
                                                    </div>
                                                </section>
                                            </div>
                                        </div>
                                    </t>

                                </div><!-- /s_tabs_content -->
                            </div><!-- /s_tabs_main -->
                        </div>
                    </section>
                </t>

                <!-- ── Extra editable zone below tabs ─────────────────────────────────── -->
                <div class="oe_structure oe_empty" id="oe_structure_profile_extra"/>

            </div><!-- /wrap -->
        </t>
    </template>

</odoo>
