<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ════════════════════ List ════════════════════ -->
    <record id="view_ypu_teacher_category_list" model="ir.ui.view">
        <field name="name">ypu.teacher.category.list</field>
        <field name="model">ypu.teacher.category</field>
        <field name="arch" type="xml">
            <list default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
                <field name="teacher_count" string="# Teachers"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════ Form ════════════════════ -->
    <record id="view_ypu_teacher_category_form" model="ir.ui.view">
        <field name="name">ypu.teacher.category.form</field>
        <field name="model">ypu.teacher.category</field>
        <field name="arch" type="xml">
            <form string="Teacher Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════ Action ════════════════════ -->
    <record id="action_ypu_teacher_category" model="ir.actions.act_window">
        <field name="name">Teacher Categories</field>
        <field name="res_model">ypu.teacher.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
