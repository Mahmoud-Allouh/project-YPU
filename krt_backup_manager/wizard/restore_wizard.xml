<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="db_restore_instance_wizard_view_form" model="ir.ui.view">
            <field name="name">db.restore.instance.wizard.view.form</field>
            <field name="model">db.restore.instance.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="restore_db_name"/>
                                <field name="is_copy"/>
                            </group>
                            <group>
                                <field name="restore_master_pwd" password="True"/>
                                <field name="reset_admin_account_access"/>
                            </group>
                        </group>
                        <group string="Admin Access" invisible="reset_admin_account_access != True">
                            <group>
                                <field name="admin_username" required="reset_admin_account_access == True"/>
                            </group>
                            <group>
                                <field name="admin_password" required="reset_admin_account_access == True" password="True" />
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                        <button string="Restore Backup" name="restorer" type="object" class="oe_highlight" data-hotkey="q"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="db_restore_instance_wizard_wizard_action" model="ir.actions.act_window">
            <field name="name">Restore Database</field>
            <field name="res_model">db.restore.instance.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
