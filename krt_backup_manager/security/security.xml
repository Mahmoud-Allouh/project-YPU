<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.module.category" id="module_krt_backup_manager_category">
        <field name="name">Manage Automatic Backup</field>
        <field name="description">Manage Automatic Backup</field>
        <field name="sequence">20</field>
    </record>

    <record model="res.groups.privilege" id="res_groups_privilege_krt_backup_manager">
        <field name="name">Backup Manager</field>
        <field name="category_id" ref="module_krt_backup_manager_category"/>
    </record>

    <record id="module_krt_backup_manager_group_user" model="res.groups">
        <field name="name">Access the module</field>
        <field name="privilege_id" ref="res_groups_privilege_krt_backup_manager"/>
        <field name="implied_ids" eval="[(4,ref('base.group_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>

    <record id="module_krt_backup_manager_restore_group" model="res.groups">
        <field name="name">Restore a Backup</field>
        <field name="privilege_id" ref="res_groups_privilege_krt_backup_manager"/>
        <field name="implied_ids" eval="[(4,ref('krt_backup_manager.module_krt_backup_manager_group_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>

    <record id="module_krt_backup_manager_download_group" model="res.groups">
        <field name="name">Download a Backup</field>
        <field name="privilege_id" ref="res_groups_privilege_krt_backup_manager"/>
        <field name="implied_ids" eval="[(4,ref('krt_backup_manager.module_krt_backup_manager_group_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>

    <record id="module_krt_backup_manager_delete_group" model="res.groups">
        <field name="name">Delete a Backup</field>
        <field name="privilege_id" ref="res_groups_privilege_krt_backup_manager"/>
        <field name="implied_ids" eval="[(4,ref('krt_backup_manager.module_krt_backup_manager_group_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>
</odoo>
