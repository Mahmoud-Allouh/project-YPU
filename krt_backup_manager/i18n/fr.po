#. module: krt_backup_manager
#: model:mail.template,body_html:krt_backup_manager.mail_template_data_db_backup_successful
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px;\">\n"
"                        <span>Hello\n"
"                            <t t-out=\"object.notify_user_id.name\"></t>,\n"
"                        </span>\n"
"                        <br>\n"
"                        <br>\n"
"                        <span style=\"margin-top: 8px;\">A database backup of\n"
"                            <i>\n"
"                                <t t-out=\"object.db_name\"></t>\n"
"                            </i>\n"
"                            has been successfully generated and stored at\n"
"                            <t t-if=\"object.backup_destination == 'local'\">\n"
"                                <i>Local</i>\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'ftp'\">\n"
"                                <i>FTP Server</i>\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'sftp'\">\n"
"                                <i>SFTP Server</i>\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'next_cloud'\">\n"
"                                <i>NextCloud</i>\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'amazon_s3'\">\n"
"                                <i>Amazon S3</i>.\n"
"                            </t>\n"
"                            <br>\n"
"                            <br>\n"
"                            Database name:\n"
"                            <t t-out=\"object.db_name\"></t>\n"
"                            <br>\n"
"                            Destination:\n"
"                            <t t-if=\"object.backup_destination == 'local'\">\n"
"                                Local\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'ftp'\">\n"
"                                FTP Server\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'sftp'\">\n"
"                                SFTP Server\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'next_cloud'\">\n"
"                                NextCloud\n"
"                            </t>\n"
"                            <t t-elif=\"object.backup_destination == 'amazon_s3'\">\n"
"                                Amazon S3\n"
"                            </t>\n"
"                            <t t-if=\"object.backup_destination in ('local', 'ftp', 'sftp', 'next_cloud', 'amazon_s3')\">\n"
"                                <br>\n"
"                                Backup location:\n"
"                                <t t-if=\"object.backup_destination == 'local'\">\n"
"                                    <t t-out=\"object.backup_path\"></t>\n"
"                                </t>\n"
"                                <t t-elif=\"object.backup_destination == 'ftp'\">\n"
"                                    <t t-out=\"object.ftp_path\"></t>\n"
"                                </t>\n"
"                                <t t-elif=\"object.backup_destination == 'sftp'\">\n"
"                                    <t t-out=\"object.sftp_path\"></t>\n"
"                                </t>\n"
"                                <t t-elif=\"object.backup_destination == 'next_cloud'\">\n"
"                                    <t t-out=\"object.nextcloud_folder_key\"></t>\n"
"                                </t>\n"
"                                <t t-elif=\"object.backup_destination == 'amazon_s3'\">\n"
"                                    <t t-out=\"object.aws_folder_name\"></t>\n"
"                                </t>\n"
"                            </t>\n"
"                            <br>\n"
"                            Backup type:\n"
"                            <t t-out=\"object.backup_format\"></t>\n"
"                            <br>\n"
"                            Backup file name:\n"
"                            <t t-out=\"object.backup_filename\"></t>\n"
"                        </span>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""

