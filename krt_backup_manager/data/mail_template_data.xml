<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <!-- Notification of database backup success -->
        <record id="mail_template_data_db_backup_successful" model="mail.template">
            <field name="name">Database backup successful: Notification</field>
            <field name="model_id" ref="krt_backup_manager.model_db_backup_configure" />
            <field name="subject">Database backup successful: {{ object.db_name }}</field>
            <field name="email_to">{{ object.notify_user_id.email_formatted }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px;">
                        <span>Hello
                            <t t-out="object.notify_user_id.name" />,
                        </span>
                        <br />
                        <br />
                        <span style="margin-top: 8px;">A database backup of
                            <i>
                                <t t-out="object.db_name" />
                            </i>
                            has been successfully generated and stored at
                            <t t-if="object.backup_destination == 'local'">
                                <i>Local</i>
                            </t>
                            <t t-elif="object.backup_destination == 'ftp'">
                                <i>FTP Server</i>
                            </t>
                            <t t-elif="object.backup_destination == 'sftp'">
                                <i>SFTP Server</i>
                            </t>
                            <t t-elif="object.backup_destination == 'next_cloud'">
                                <i>NextCloud</i>
                            </t>
                            <t t-elif="object.backup_destination == 'amazon_s3'">
                                <i>Amazon S3</i>.
                            </t>
                            <br />
                            <br />
                            Database name:
                            <t t-out="object.db_name" />
                            <br />
                            Destination:
                            <t t-if="object.backup_destination == 'local'">
                                Local
                            </t>
                            <t t-elif="object.backup_destination == 'ftp'">
                                FTP Server
                            </t>
                            <t t-elif="object.backup_destination == 'sftp'">
                                SFTP Server
                            </t>
                            <t t-elif="object.backup_destination == 'next_cloud'">
                                NextCloud
                            </t>
                            <t t-elif="object.backup_destination == 'amazon_s3'">
                                Amazon S3
                            </t>
                            <t t-if="object.backup_destination in ('local', 'ftp', 'sftp', 'next_cloud', 'amazon_s3')">
                                <br />
                                Backup location:
                                <t t-if="object.backup_destination == 'local'">
                                    <t t-out="object.backup_path" />
                                </t>
                                <t t-elif="object.backup_destination == 'ftp'">
                                    <t t-out="object.ftp_path" />
                                </t>
                                <t t-elif="object.backup_destination == 'sftp'">
                                    <t t-out="object.sftp_path" />
                                </t>
                                <t t-elif="object.backup_destination == 'next_cloud'">
                                    <t t-out="object.nextcloud_folder_key" />
                                </t>
                                <t t-elif="object.backup_destination == 'amazon_s3'">
                                    <t t-out="object.aws_folder_name" />
                                </t>
                            </t>
                            <br />
                            Backup type:
                            <t t-out="object.backup_format" />
                            <br />
                            Backup file name:
                            <t t-out="object.backup_filename" />
                        </span>
                    </p>
                </div>
            </field>
        </record>

        <!-- Notification of database backup failure -->
        <record id="mail_template_data_db_backup_failed" model="mail.template">
            <field name="name">Database backup failed: Notification</field>
            <field name="model_id" ref="krt_backup_manager.model_db_backup_configure" />
            <field name="subject">Database backup failed: {{ object.db_name }}</field>
            <field name="email_to">{{ object.notify_user_id.email_formatted }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px;">
                        <span>Hello
                            <t t-out="object.notify_user_id.name" />,
                        </span>
                        <br />
                        <br />
                        <span style="margin-top: 8px;">The database backup of
                            <i>
                                <t t-out="object.db_name" />
                            </i>
                            has failed.
                            <br />
                            <br />
                            Database name:
                            <t t-out="object.db_name" />
                            <br />
                            Destination:
                            <t t-if="object.backup_destination == 'local'">
                                Local
                            </t>
                            <t t-elif="object.backup_destination == 'ftp'">
                                FTP Server
                            </t>
                            <t t-elif="object.backup_destination == 'sftp'">
                                SFTP Server
                            </t>
                            <t t-elif="object.backup_destination == 'next_cloud'">
                                NextCloud
                            </t>
                            <t t-elif="object.backup_destination == 'amazon_s3'">
                                Amazon S3
                            </t>
                            <t t-if="object.backup_destination in ('local', 'ftp', 'sftp', 'next_cloud','amazon_s3')">
                                <br />
                                Backup location:
                                <t t-if="object.backup_destination == 'local'">
                                    <t t-out="object.backup_path" />
                                </t>
                                <t t-elif="object.backup_destination == 'ftp'">
                                    <t t-out="object.ftp_path" />
                                </t>
                                <t t-elif="object.backup_destination == 'sftp'">
                                    <t t-out="object.sftp_path" />
                                </t>
                                <t t-elif="object.backup_destination == 'next_cloud'">
                                    <t t-out="object.nextcloud_folder_key" />
                                </t>
                                <t t-elif="object.backup_destination == 'amazon_s3'">
                                    <t t-out="object.aws_folder_name" />
                                </t>
                            </t>
                            <br />
                            Backup type:
                            <t t-out="object.backup_format" />
                            <br />
                            <br />
                            <b>Error message:</b>
                            <br />
                            <i>
                                <t t-out="object.generated_exception" />
                            </i>
                        </span>
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>

