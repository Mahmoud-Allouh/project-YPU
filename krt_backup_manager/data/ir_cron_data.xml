<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">
        <!-- Schedule action for deleting automatic database backup-->
        <record id="ir_cron_auto_db_backup" model="ir.cron">
            <field name="name">Automatic deletion of different backups</field>
            <field name="model_id" ref="model_db_backup_configure"/>
            <field name="state">code</field>
            <field name="code">model._schedule_auto_delete()</field>
            <field name="interval_number">5</field>
            <field name="priority">2</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=5)).strftime('%Y-%m-%d %H:%M:%S')" />
        </record>
        <!-- Schedule action for deleting automatic database backup-->
        <record id="ir_cron_auto_check_if_exist" model="ir.cron">
            <field name="name">Automatic check if backup exists</field>
            <field name="model_id" ref="model_db_backup_instance"/>
            <field name="state">code</field>
            <field name="code">model._auto_check_if_file_exist()</field>
            <field name="interval_number">30</field>
            <field name="priority">3</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(minutes=30)).strftime('%Y-%m-%d %H:%M:%S')" />
        </record>
    </data>
</odoo>
