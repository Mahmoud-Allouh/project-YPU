<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_website_edit_restriction" model="ir.ui.view">
        <field name="name">res.users.view.form.inherit.website.edit.restriction</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Website Edit Restriction" name="website_edit_restriction">
                    <group>
                        <field name="website_restriction_enabled"/>
                    </group>
                    <group string="Allowed Content" invisible="not website_restriction_enabled">
                        <field name="website_allowed_page_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="website_allowed_blog_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
