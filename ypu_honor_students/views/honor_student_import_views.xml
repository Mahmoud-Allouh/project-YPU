<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_ypu_honor_student_import_form" model="ir.ui.view">
        <field name="name">ypu.honor.student.import.form</field>
        <field name="model">ypu.honor.student.import</field>
        <field name="arch" type="xml">
            <form string="Import Honor Students from Excel">
                <header>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="state == 'done'"/>
                    <button name="action_download_template" string="⬇ Download Template"
                            type="object" class="btn-secondary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </header>
                <sheet>
                    <group string="Upload File" invisible="state == 'done'">
                        <group>
                            <field name="excel_file" filename="filename" widget="binary"
                                   string="Excel File (.xlsx)"/>
                            <field name="filename" invisible="1"/>
                            <field name="update_existing"/>
                        </group>
                        <group>
                            <div class="alert alert-info" role="alert" colspan="2">
                                <strong>How to import:</strong>
                                <ol class="mb-0 mt-1">
                                    <li>Click <em>Download Template</em>.</li>
                                    <li>Fill one student per row. Required columns are Name, Faculty, Year, Study Year, Semester.</li>
                                    <li>Upload the file and click <em>Import</em>.</li>
                                </ol>
                            </div>
                        </group>
                    </group>

                    <group string="Import Results" invisible="state == 'draft'">
                        <group>
                            <field name="result_created" string="Records Created" readonly="1"/>
                            <field name="result_updated" string="Records Updated" readonly="1"/>
                            <field name="result_skipped" string="Rows Skipped" readonly="1"/>
                        </group>
                    </group>

                    <field name="result_log" invisible="state == 'draft'"
                           readonly="1" widget="text" string="Import Log"
                           options="{'rows': 15}"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ypu_honor_student_import" model="ir.actions.act_window">
        <field name="name">Import Honor Students from Excel</field>
        <field name="res_model">ypu.honor.student.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_ypu_honor_student_import"
              name="Import from Excel"
              parent="menu_ypu_honor_configuration"
              action="action_ypu_honor_student_import"
              sequence="40"/>

</odoo>
