<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_ypu_honor_student_search" model="ir.ui.view">
        <field name="name">ypu.honor.student.search</field>
        <field name="model">ypu.honor.student</field>
        <field name="arch" type="xml">
            <search string="Honor Students">
                <field name="name"/>
                <field name="student_number"/>
                <field name="faculty_id"/>
                <field name="year_id" string="Year"/>
                <field name="study_year_id" string="Study Year"/>
                <field name="semester"/>
                <field name="honor_title"/>
                <filter name="published" string="Published" domain="[('website_published','=',True)]"/>
                <filter name="public" string="Public" domain="[('is_public','=',True)]"/>
                <filter name="active_only" string="Active" domain="[('active','=',True)]"/>
                <separator/>
                <filter name="group_faculty" string="Faculty" context="{'group_by':'faculty_id'}"/>
                <filter name="group_year" string="Year" context="{'group_by':'year_id'}"/>
                <filter name="group_study_year" string="Study Year" context="{'group_by':'study_year_id'}"/>
                <filter name="group_semester" string="Semester" context="{'group_by':'semester'}"/>
            </search>
        </field>
    </record>

    <record id="view_ypu_honor_student_list" model="ir.ui.view">
        <field name="name">ypu.honor.student.list</field>
        <field name="model">ypu.honor.student</field>
        <field name="arch" type="xml">
            <list default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="image_1920" widget="image" options="{'size': [32, 32]}"/>
                <field name="name"/>
                <field name="student_number" optional="show"/>
                <field name="faculty_id"/>
                <field name="year_id" string="Year"/>
                <field name="study_year_id" string="Study Year" optional="show"/>
                <field name="semester"/>
                <field name="gpa" optional="show"/>
                <field name="honor_title" optional="show"/>
                <field name="website_published"/>
                <field name="is_public"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ypu_honor_student_form" model="ir.ui.view">
        <field name="name">ypu.honor.student.form</field>
        <field name="model">ypu.honor.student</field>
        <field name="arch" type="xml">
            <form string="Honor Student">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'size': [180, 180]}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Student name"/></h1>
                    </div>

                    <group>
                        <group string="Academic Info">
                            <field name="student_number"/>
                            <field name="faculty_id"/>
                            <field name="year_id" string="Year"/>
                            <field name="study_year_id" string="Study Year"/>
                            <field name="semester"/>
                            <field name="gpa"/>
                            <field name="honor_title"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Website Visibility">
                            <field name="website_published"/>
                            <field name="is_public"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Achievement Summary">
                            <field name="achievement" placeholder="Optional achievement details shown on the website card..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ypu_honor_student" model="ir.actions.act_window">
        <field name="name">Honor Students</field>
        <field name="res_model">ypu.honor.student</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ypu_honor_student_search"/>
        <field name="context">{'search_default_published': 1}</field>
    </record>

    <menuitem id="menu_ypu_honor_root" name="YPU Honor Students" sequence="15"/>
    <menuitem id="menu_ypu_honor_students" name="Students"
              parent="menu_ypu_honor_root" action="action_ypu_honor_student" sequence="10"/>
    <menuitem id="menu_ypu_honor_configuration" name="Configuration"
              parent="menu_ypu_honor_root" sequence="90"/>
    <menuitem id="menu_ypu_honor_faculties" name="Faculties"
              parent="menu_ypu_honor_configuration" action="action_ypu_honor_faculty" sequence="10"/>
    <menuitem id="menu_ypu_honor_years" name="Years"
              parent="menu_ypu_honor_configuration" action="action_ypu_honor_year" sequence="20"/>
    <menuitem id="menu_ypu_honor_study_years" name="Study Years"
              parent="menu_ypu_honor_configuration" action="action_ypu_honor_study_year" sequence="30"/>

</odoo>
