<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="s_honor_students" name="Honor Students">
        <section class="s_honor_students pt48 pb48"
                 data-snippet="s_honor_students"
                 data-faculty-id="0"
                 data-year-id="0"
                 data-study-year="0"
                 data-semester="0"
                 data-limit="12"
                 data-show-filters="true">
            <div class="container">
                <div class="s_honor_students_content text-center text-muted py-5">
                    <i class="fa fa-graduation-cap fa-3x mb-3 d-block"/>
                    <p>Honor students will appear here.</p>
                </div>
            </div>
        </section>
    </template>

    <template id="s_honor_students_snippet"
              inherit_id="website.snippets" name="Honor Students: Snippet Menu">
        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="ypu_honor_students.s_honor_students"
               string="Honor Students"
               group="people">
                <keywords>honor, students, faculty, semester, year, education, university</keywords>
            </t>
        </xpath>
    </template>

</odoo>
