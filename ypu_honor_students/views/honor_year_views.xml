<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_ypu_honor_year_list" model="ir.ui.view">
        <field name="name">ypu.honor.year.list</field>
        <field name="model">ypu.honor.year</field>
        <field name="arch" type="xml">
            <list default_order="sequence, code, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="student_count" string="# Students"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ypu_honor_year_form" model="ir.ui.view">
        <field name="name">ypu.honor.year.form</field>
        <field name="model">ypu.honor.year</field>
        <field name="arch" type="xml">
            <form string="Honor Student Year">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ypu_honor_year" model="ir.actions.act_window">
        <field name="name">Years</field>
        <field name="res_model">ypu.honor.year</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
