<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ════════════════════ Access rights ════════════════════ -->
    <!-- Loaded after ir.model records are reflected — safe for upgrade -->
    <record id="access_ypu_study_plan_import_user" model="ir.model.access">
        <field name="name">ypu.study.plan.import user</field>
        <field name="model_id" ref="model_ypu_study_plan_import"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    <record id="access_ypu_study_plan_import_manager" model="ir.model.access">
        <field name="name">ypu.study.plan.import manager</field>
        <field name="model_id" ref="model_ypu_study_plan_import"/>
        <field name="group_id" ref="website.group_website_designer"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ════════════════════ Wizard form ════════════════════ -->
    <record id="view_ypu_study_plan_import_form" model="ir.ui.view">
        <field name="name">ypu.study.plan.import.form</field>
        <field name="model">ypu.study.plan.import</field>
        <field name="arch" type="xml">
            <form string="Import Study Plans from Excel">
                <header>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="state == 'done'"/>
                    <button name="action_download_template" string="⬇ Download Template"
                            type="object" class="btn-secondary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </header>
                <sheet>

                    <!-- Upload section (shown before import) -->
                    <group string="Upload File" invisible="state == 'done'">
                        <group>
                            <field name="excel_file" filename="filename" widget="binary"
                                   string="Excel File (.xlsx)"/>
                            <field name="filename" invisible="1"/>
                            <field name="update_existing"/>
                        </group>
                        <group>
                            <div class="alert alert-info" role="alert" colspan="2">
                                <strong>How to import:</strong>
                                <ol class="mb-0 mt-1">
                                    <li>Click <em>Download Template</em> to get the Excel file with all columns pre-labelled.</li>
                                    <li>Each row represents a <strong>course</strong> within a section of a plan. <strong>Plan Name</strong> and <strong>Section Name</strong> are required per row.</li>
                                    <li>Rows sharing the same Plan Name reuse the same plan record (no duplicates). Rows sharing the same Plan + Section Name reuse the same section.</li>
                                    <li>Enable <em>Update existing plans</em> to overwrite the Code and Subtitle of plans that already exist.</li>
                                    <li>Upload the filled file and click <em>Import</em>.</li>
                                </ol>
                            </div>
                        </group>
                    </group>

                    <!-- Results section (shown after import) -->
                    <group string="Import Results" invisible="state == 'draft'">
                        <group>
                            <field name="result_created" string="Plans Created" readonly="1"/>
                            <field name="result_updated" string="Plans Updated" readonly="1"/>
                            <field name="result_skipped" string="Rows Skipped" readonly="1"/>
                        </group>
                    </group>

                    <field name="result_log" invisible="state == 'draft'"
                           readonly="1" widget="text" string="Import Log"
                           options="{'rows': 15}"/>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════ Action ════════════════════ -->
    <record id="action_ypu_study_plan_import" model="ir.actions.act_window">
        <field name="name">Import Study Plans from Excel</field>
        <field name="res_model">ypu.study.plan.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ════════════════════ Menu ════════════════════ -->
    <menuitem id="menu_ypu_study_plan_import"
              name="Import from Excel"
              parent="menu_ypu_study_plans_root"
              action="action_ypu_study_plan_import"
              sequence="40"/>

</odoo>
