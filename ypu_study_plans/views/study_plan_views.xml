<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         STUDY PLAN — Action
    ============================================================ -->
    <record id="action_ypu_study_plan" model="ir.actions.act_window">
        <field name="name">Study Plans</field>
        <field name="res_model">ypu.study.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Study Plan</p>
            <p>A Study Plan is a curriculum (e.g. "Faculty of Dentistry Plan") made up of
                sections (e.g. "Year 1 — Term 1") and courses.
                Drop it onto any website page using the snippet panel.</p>
        </field>
    </record>

    <!-- ============================================================
         STUDY PLAN — List
    ============================================================ -->
    <record id="view_ypu_study_plan_list" model="ir.ui.view">
        <field name="name">ypu.study.plan.list</field>
        <field name="model">ypu.study.plan</field>
        <field name="arch" type="xml">
            <list string="Study Plans">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="subtitle"/>
                <field name="section_count" string="Sections"/>
                <field name="course_count" string="Courses"/>
                <field name="total_credit_hours" string="Total CH"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         STUDY PLAN — Form
    ============================================================ -->
    <record id="view_ypu_study_plan_form" model="ir.ui.view">
        <field name="name">ypu.study.plan.form</field>
        <field name="model">ypu.study.plan</field>
        <field name="arch" type="xml">
            <form string="Study Plan">
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Plan name — e.g. Faculty of Dentistry Plan"/>
                        </h1>
                        <field name="subtitle"
                               placeholder="Short subtitle shown on the website — e.g. Academic Year 2024-2025"/>
                    </div>

                    <group>
                        <group string="Plan Info">
                            <field name="code"
                                   placeholder="Short unique code — e.g. dentistry_2024"
                                   help="Optional code used to reference this plan. Letters, digits, hyphens only."/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Statistics">
                            <field name="section_count" string="Number of Sections"/>
                            <field name="course_count" string="Total Courses"/>
                            <field name="total_credit_hours" string="Total Credit Hours"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sections" name="sections">
                            <field name="section_ids">
                                <!-- ── Section inline list ── -->
                                <list string="Sections">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Section Title"/>
                                    <field name="subtitle"/>
                                    <field name="section_type" string="Type"/>
                                    <field name="course_count" string="Courses"/>
                                    <field name="total_credit" string="Total CH"/>
                                </list>

                                <!-- ── Section popup (one level only) ── -->
                                <form string="Section">
                                    <sheet>
                                        <div class="oe_title">
                                            <label for="name" class="oe_edit_only"/>
                                            <h1>
                                                <field name="name"
                                                       placeholder="Section title — e.g. University Mandatory Requirements"/>
                                            </h1>
                                            <field name="subtitle"
                                                   placeholder="Short note — e.g. 9 credit hours"/>
                                        </div>

                                        <group>
                                            <group string="Section Settings">
                                                <field name="section_type" string="Type"/>
                                            </group>
                                            <group string="Table Display Options">
                                                <field name="show_total_row" string="Show Totals Row"/>
                                                <field name="show_prerequisite_column" string="Show Prerequisite Column"/>
                                                <field name="show_description_column" string="Show Description Column"/>
                                            </group>
                                        </group>

                                        <separator string="Courses"/>
                                        <p class="text-muted">
                                            Add courses directly in the table below. To upload a PDF or
                                            create a dedicated web page for a course, open it from the
                                            <strong>Courses</strong> menu.
                                        </p>
                                        <!-- ── Courses: pure inline editing, NO nested popup ── -->
                                        <field name="course_ids">
                                            <list string="Courses" editable="bottom">
                                                <field name="sequence" widget="handle"/>
                                                <field name="code" string="Code"/>
                                                <field name="name_ar" string="Arabic Name"/>
                                                <field name="name_en" string="English Name"/>
                                                <field name="theory_hours" string="Theory"/>
                                                <field name="practical_hours" string="Practical"/>
                                                <field name="credit_hours" string="CH"/>
                                                <field name="prerequisite" string="Prerequisite" optional="show"/>
                                                <field name="pdf_file" filename="pdf_filename"
                                                       widget="binary" string="PDF" optional="hide"/>
                                                <field name="pdf_filename" column_invisible="1"/>
                                            </list>
                                        </field>
                                        <group class="oe_subtotal_footer oe_right" colspan="2" name="totals">
                                            <field name="total_theory" string="Total Theory"/>
                                            <field name="total_practical" string="Total Practical"/>
                                            <field name="total_credit" string="Total Credit Hours"/>
                                        </group>

                                        <separator string="Section Description"/>
                                        <field name="description"
                                               nolabel="1"
                                               placeholder="Optional rich text shown above the course table on the website…"/>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Plan Description" name="description">
                            <field name="description" nolabel="1"
                                   placeholder="Optional rich-text description shown above the plan on the website…"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         STUDY PLAN — Search
    ============================================================ -->
    <record id="view_ypu_study_plan_search" model="ir.ui.view">
        <field name="name">ypu.study.plan.search</field>
        <field name="model">ypu.study.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="subtitle"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- ============================================================
         COURSE — Action (top-level: page button works here)
    ============================================================ -->
    <record id="action_ypu_study_plan_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">ypu.study.plan.course</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No courses yet</p>
            <p>Courses are created inside a Study Plan's sections. Open any course here to
                upload a PDF, write a description, and create its dedicated web page.</p>
        </field>
    </record>

    <!-- ============================================================
         COURSE — List
    ============================================================ -->
    <record id="view_ypu_study_plan_course_list" model="ir.ui.view">
        <field name="name">ypu.study.plan.course.list</field>
        <field name="model">ypu.study.plan.course</field>
        <field name="arch" type="xml">
            <list string="Courses">
                <field name="code" string="Code"/>
                <field name="name_ar" string="Arabic Name"/>
                <field name="name_en" string="English Name"/>
                <field name="plan_id" string="Plan"/>
                <field name="section_id" string="Section"/>
                <field name="credit_hours" string="CH"/>
                <field name="page_url" string="Web Page" readonly="1" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         COURSE — Form (full page, page button works reliably)
    ============================================================ -->
    <record id="view_ypu_study_plan_course_form" model="ir.ui.view">
        <field name="name">ypu.study.plan.course.form</field>
        <field name="model">ypu.study.plan.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <header>
                    <button name="action_create_course_page" type="object"
                            string="Create Web Page" class="btn-primary"
                            invisible="website_page_id"/>
                    <button name="action_create_course_page" type="object"
                            string="Update Web Page" class="btn-secondary"
                            invisible="not website_page_id"
                            confirm="This rebuilds the page from the course data. Any custom edits made in the website builder will be replaced. Continue?"/>
                    <button name="action_open_course_page" type="object"
                            string="Open Page" class="btn-secondary"
                            invisible="not website_page_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_course_page" type="object"
                                class="oe_stat_button" icon="fa-globe"
                                invisible="not website_page_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">View</span>
                                <span class="o_stat_text">Page</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="code" string="Course Code"/>
                        <h1><field name="code" placeholder="e.g. URQ 121"/></h1>
                    </div>

                    <group>
                        <group string="Course Name">
                            <field name="name_ar" string="Arabic Name" placeholder="اسم المادة بالعربية"/>
                            <field name="name_en" string="English Name" placeholder="Course name in English"/>
                            <field name="prerequisite" string="Prerequisite" placeholder="e.g. URQ 211"/>
                        </group>
                        <group string="Hours">
                            <field name="theory_hours" string="Theory Hours"/>
                            <field name="practical_hours" string="Practical Hours"/>
                            <field name="credit_hours" string="Credit Hours (CH)"/>
                        </group>
                    </group>

                    <group>
                        <group string="Belongs To">
                            <field name="plan_id" readonly="1"/>
                            <field name="section_id"/>
                        </group>
                        <group string="Downloadable PDF">
                            <field name="pdf_file" filename="pdf_filename" widget="binary"
                                   string="Upload PDF (optional)"
                                   help="Visitors can download this file from the course page and from the plan table."/>
                            <field name="pdf_filename" invisible="1"/>
                        </group>
                    </group>

                    <group string="Description">
                        <field name="description" nolabel="1"
                               placeholder="Shown on the course's web page…"/>
                    </group>

                    <!-- ── Website page status ── -->
                    <separator string="Website Page"/>
                    <div role="status" class="alert alert-info mb-2"
                         invisible="website_page_id">
                        This course has no web page yet. Click
                        <strong>Create Web Page</strong> above to generate one — then you can
                        customize it in the website builder.
                    </div>
                    <div role="status" class="alert alert-success mb-2"
                         invisible="not website_page_id">
                        The web page is live. Use <strong>Open Page</strong> to view it, or
                        edit it in the website builder.
                    </div>
                    <group invisible="not website_page_id">
                        <field name="page_url" string="Page Address" widget="url" readonly="1"/>
                    </group>

                    <!-- hidden technical fields -->
                    <field name="website_slug" invisible="1"/>
                    <field name="website_page_id" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         COURSE — Search
    ============================================================ -->
    <record id="view_ypu_study_plan_course_search" model="ir.ui.view">
        <field name="name">ypu.study.plan.course.search</field>
        <field name="model">ypu.study.plan.course</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name_ar"/>
                <field name="name_en"/>
                <field name="plan_id"/>
                <field name="section_id"/>
                <filter string="With Web Page" name="has_page" domain="[('website_page_id','!=',False)]"/>
                <filter string="Without Web Page" name="no_page" domain="[('website_page_id','=',False)]"/>
                <separator/>
                <filter string="Plan" name="group_plan" context="{'group_by':'plan_id'}"/>
                <filter string="Section" name="group_section" context="{'group_by':'section_id'}"/>
            </search>
        </field>
    </record>

</odoo>
